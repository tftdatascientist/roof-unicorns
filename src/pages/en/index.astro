---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import Gallery from '../../components/Gallery.astro';
import UnicornOfDay from '../../components/UnicornOfDay.astro';
import CatsTrapStory from '../../components/CatsTrapStory.astro';
import RooftopStories from '../../components/RooftopStories.astro';
import Footer from '../../components/Footer.astro';

const locale = 'en' as const;
---

<Layout locale={locale}>
  <Navbar locale={locale} />
  <Hero locale={locale} />
  <Gallery locale={locale} />
  <UnicornOfDay locale={locale} />
  <CatsTrapStory locale={locale} />
  <RooftopStories locale={locale} />
  <Footer locale={locale} />
</Layout>
