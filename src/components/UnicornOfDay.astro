---
import type { Locale } from '../i18n/utils';
import { getTranslations, getUnicornOfDay } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const unicorn = getUnicornOfDay(locale);

