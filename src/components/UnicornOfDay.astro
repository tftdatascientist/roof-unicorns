  "https://lh3.googleusercontent.com/aida-public/AB6AXuCvTChsH2dwxCKtseCaotqyMBUhzsOl9J6u14yqBupTJySUZcZtwvGC_ObvOb7ZWGJt9zSNK1fWk4z0Mhnm4A-9PQomMyF2tt-F1FwDAK0_D4Y5S7HbkCKAWbYdooYNMigi7q7HHh0tEElr_C4I9b226AZdQOom065ChI50NC-3dcA6C-K7u9U5KEB75c2r0bPfddxCtflyyMka8F7rxceQhkspqI01WhPxk7BKByooozqvkOcVKmqNAvh7OnQx4Jj93oeW391M2mI",
  "https://lh3.googleusercontent.com/aida-public/AB6AXuDKQ3fYkgS5JcCUQLDoJVXd_LgVhKU2ALtumkkq8-52BJ7GObu9TrnlBfcpbaXsr5zB7jyvY7XneczynyaYuTo6qIpDbN2PKH2-O3bA840I1emWmEqnWB3mXDcR1UFKLmgxe_bKuF3DUCXIQ43BJEtJ8jdmwYGJanlCD-SnWB9x9j-UfdwPK2969eoDPE6t1BmtoHdDARA8T6h28X58Uqm9bbiDV5b91JziWtOfbqtGLAqulx8XwSnEDdDom5v15o-NKMm_vb5UV5o"
];

const today = new Date();
const dayIndex = Math.floor(today.getTime() / (1000 * 60 * 60 * 24)) % unicornImages.length;
const unicornImage = unicornImages[dayIndex];
---

<section class="py-32 px-8 bg-surface" id="unicorn-day">
  <div class="max-w-6xl mx-auto">
    <div class="bg-surface-container-highest rounded-3xl p-10 md:p-20 relative overflow-hidden flex flex-col md:flex-row items-center gap-16 shadow-[0_12px_40px_rgba(139,92,246,0.15)] border border-primary/10">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary/20 rounded-full blur-[100px]"></div>
      <div class="relative shrink-0">
        <div class="w-48 h-48 md:w-64 md:h-64 rounded-full p-2 border-4 border-dashed border-secondary animate-[spin_20s_linear_infinite]"></div>
        <div class="absolute inset-0 m-3 rounded-full overflow-hidden border-4 border-primary shadow-[0_0_30px_rgba(186,158,255,0.4)]">
          <img alt={unicorn.name} class="w-full h-full object-cover" src={unicornImage} />
        </div>
      </div>
      <div class="relative z-10 space-y-8">
        <div>
          <span class="bg-secondary/20 text-secondary-dim px-4 py-1 rounded-full text-xs font-headline tracking-widest uppercase">{t.unicornOfDay.badge}</span>
          <h2 class="font-headline text-4xl md:text-6xl mt-4 tracking-tighter uppercase leading-tight">{unicorn.name}</h2>
          <p class="font-body text-primary text-xl font-semibold mt-2">{unicorn.title}</p>
        </div>
        <blockquote class="font-headline text-2xl md:text-3xl text-on-surface italic leading-relaxed">
          {unicorn.quote}
        </blockquote>
        <div class="pt-4">
          <button class="bg-primary text-on-primary px-8 py-4 rounded-xl font-headline tracking-widest uppercase text-sm hover:shadow-[0_0_20px_rgba(132,85,239,0.5)] transition-all">
            {t.unicornOfDay.button}
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
