---
import type { Locale } from '../i18n/utils';
import { getTranslations } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<footer class="w-full">
  <div class="bg-gradient-to-r from-[#ffd16f] via-[#ec63ff] to-[#ba9eff] py-12 flex flex-col items-center justify-center space-y-4 w-full shadow-[0_-10px_40px_rgba(236,99,255,0.2)]">
    <h2 class="text-[#0e0e0e] font-black uppercase tracking-[0.2em] text-center font-['Epilogue'] text-3xl md:text-5xl">{t.footer.headline}</h2>
    <div class="flex items-center space-x-6 text-[#0e0e0e]/80 font-['Manrope'] text-xs font-bold tracking-widest uppercase">
      <a class="hover:opacity-80 transition-opacity" href="#">{t.footer.privacy}</a>
      <span class="w-1 h-1 bg-[#0e0e0e] rounded-full"></span>
      <a class="hover:opacity-80 transition-opacity" href="#">{t.footer.terms}</a>
    </div>
  </div>
</footer>
